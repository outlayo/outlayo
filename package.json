{
  "name": "outlayo",
  "version": "0.1.0",
  "private": true,
  "description": "Outlayo OSS monorepo for self-hosted spend visibility, connectors, and app-side usage ingestion.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "css:build": "tailwindcss -i ./apps/server/src/styles/tailwind.css -o ./apps/server/public/styles.css --minify",
    "css:watch": "tailwindcss -i ./apps/server/src/styles/tailwind.css -o ./apps/server/public/styles.css --watch",
    "dev": "npm run css:build && tsx apps/server/src/index.ts",
    "website:dev": "npm run dev --workspace @outlayo/website",
    "website:build": "npm run build --workspace @outlayo/website",
    "website:preview": "npm run preview --workspace @outlayo/website",
    "cli": "node --import tsx apps/cli/src/index.ts",
    "cli:init": "npm run cli -- init",
    "cli:doctor": "npm run cli -- doctor",
    "verify:live": "node --import tsx scripts/verify-connectors-live.ts",
    "start": "npm run css:build && node --import tsx apps/server/src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.9.2",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
